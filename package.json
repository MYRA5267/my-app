{
  "name": "myra",
  "private": true,
  "version": "1.10.0",
  "description": "MYRA — музыка, независимые артисты и живое сообщество.",
  "author": "MYRA Team",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "main": "main.js",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:cross-browser": "playwright test tests/e2e/app-launch.spec.ts tests/e2e/onboarding.spec.ts",
    "electron:dev": "electron .",
    "electron:build": "electron-builder"
  },
  "build": {
    "appId": "app.myra.music",
    "productName": "MYRA",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "dist/favicon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "dist/favicon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "dist/favicon.png"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@fontsource/ibm-plex-mono": "5.3.0",
    "@fontsource/plus-jakarta-sans": "5.3.0",
    "@fontsource/sora": "5.3.0",
    "@sentry/react": "10.67.0",
    "@supabase/supabase-js": "^2.110.8",
    "eruda": "^3.4.3",
    "motion": "12.42.2",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "sonner": "2.0.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.8",
    "@playwright/test": "^1.56.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "^10.5.2",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^7.0.2",
    "vite": "6.4.3",
    "vitest": "^4.1.10"
  }
}
