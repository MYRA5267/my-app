{
  "name": "myra",
  "private": true,
  "version": "1.8.0",
  "main": "main.js",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "electron:dev": "electron .",
    "electron:build": "electron-builder"
  },
  "build": {
    "appId": "app.myra.music",
    "productName": "MYRA",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "dist/favicon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "dist/favicon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "dist/favicon.png"
    }
  },
  "dependencies": {
    "@capacitor/android": "^7.6.8",
    "@capacitor/core": "^7.6.8",
    "@capacitor/ios": "^7.6.8",
    "@sentry/react": "10.65.0",
    "@supabase/supabase-js": "^2.45.4",
    "eruda": "^3.4.3",
    "motion": "12.23.24",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sonner": "2.0.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.8",
    "@playwright/test": "^1.56.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "^10.5.2",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^7.0.2",
    "vite": "6.3.5",
    "vitest": "^4.1.10"
  }
}
