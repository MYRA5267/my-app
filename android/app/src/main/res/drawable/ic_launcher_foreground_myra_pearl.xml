<?xml version="1.0" encoding="utf-8"?>
<!-- Логотип MYRA, colorway v2 «перелив»: градиентная «M» фиолет → небо → роза
     (совпадает с - -brand-grad приложения) + жемчужный блик по верху обводки.
     Используется ТОЛЬКО как foreground адаптивной иконки (mipmap-anydpi-v26,
     то есть API 26+, где градиенты в векторах гарантированно работают);
     monochrome-слой остаётся на плоской ic_launcher_foreground_myra — систему
     интересует лишь альфа-маска, и однотонная версия там надёжнее.
     «M» занимает центральные 54% вьюпорта — целиком в safe zone (66%). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="240"
    android:viewportHeight="240">
    <path
        android:pathData="M60,178 L60,62 L120,132 L180,62 L180,178"
        android:strokeWidth="36"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="55"
                android:startY="55"
                android:endX="185"
                android:endY="185">
                <item android:offset="0" android:color="#FFA78BFA"/>
                <item android:offset="0.5" android:color="#FF7DD3FC"/>
                <item android:offset="1" android:color="#FFF6B8C8"/>
            </gradient>
        </aapt:attr>
    </path>
    <path
        android:pathData="M60,170 L60,54 L120,124 L180,54 L180,170"
        android:strokeColor="#59F9DCE4"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"/>
</vector>
